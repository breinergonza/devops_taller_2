{
  "info": {
    "_postman_id": "blacklist-api-collection",
    "name": "Blacklist Microservice API",
    "description": "Colección de endpoints para el microservicio de gestión de listas negras de emails. Incluye pruebas automatizadas y uso de variables dinámicas para validación completa.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://blacklist-alb-1329342580.us-east-1.elb.amazonaws.com",
      "type": "string",
      "description": "URL base del servidor activo (actualmente apuntando al ALB en AWS)"
    },
    {
      "key": "local_base_url",
      "value": "http://localhost:5000",
      "type": "string",
      "description": "URL base para pruebas en entorno local"
    },
    {
      "key": "bearer_token",
      "value": "uniandes-devops-2026",
      "type": "string",
      "description": "Token estático de autorización"
    },
    {
      "key": "dynamic_test_email",
      "value": "",
      "type": "string",
      "description": "Email autogenerado durante el flujo de pruebas"
    },
    {
      "key": "app_uuid",
      "value": "11111111-1111-1111-1111-111111111111",
      "type": "string",
      "description": "UUID de la aplicación simulada"
    }
  ],
  "item": [
    {
      "name": "Health & Info",
      "item": [
        {
          "name": "Health Check - GET /ping",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains status ok', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql('ok');",
                  "});",
                  "",
                  "pm.test('Response contains a valid timestamp', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.timestamp).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/ping",
              "host": ["{{base_url}}"],
              "path": ["ping"]
            },
            "description": "Health check endpoint (no auth required)"
          }
        },
        {
          "name": "Service Info - GET /",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 404', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            }
          }
        }
      ]
    },
    {
      "name": "Blacklist Operations",
      "item": [
        {
          "name": "Add Email to Blacklist - POST /blacklists",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generamos un correo aleatorio para la prueba y lo guardamos en las variables de colección",
                  "let randomId = Math.floor(Math.random() * 1000000);",
                  "let generatedEmail = `automated_test_${randomId}@example.com`;",
                  "pm.collectionVariables.set('dynamic_test_email', generatedEmail);",
                  "console.log('Se utilizará el siguiente correo para la prueba dinámica: ' + generatedEmail);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response includes confirmation message', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.msg).to.include('agregado');",
                  "});",
                  "",
                  "pm.test('Response includes the created record id', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Response matches the dynamically generated email', function () {",
                  "    var jsonData = pm.response.json();",
                  "    var expectedEmail = pm.collectionVariables.get('dynamic_test_email');",
                  "    pm.expect(jsonData.email).to.eql(expectedEmail);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearer_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded",
                "type": "text"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "email",
                  "value": "{{dynamic_test_email}}",
                  "type": "text"
                },
                {
                  "key": "app_uuid",
                  "value": "{{app_uuid}}",
                  "type": "text"
                },
                {
                  "key": "blocked_reason",
                  "value": "Automated Postman Run Flow Test",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/blacklists",
              "host": ["{{base_url}}"],
              "path": ["blacklists"]
            }
          }
        },
        {
          "name": "Check Email Blacklist - GET /blacklists/{email}",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Email is correctly found in the blacklist (in_blacklist = true)', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.in_blacklist).to.be.true;",
                  "});",
                  "",
                  "pm.test('Blocked reason matches what was submitted', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.blocked_reason).to.eql('Automated Postman Run Flow Test');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearer_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/blacklists/{{dynamic_test_email}}",
              "host": ["{{base_url}}"],
              "path": ["blacklists", "{{dynamic_test_email}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Error Validation Flow",
      "item": [
        {
          "name": "Missing Authentication Token - GET /blacklists",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401 Unauthorized', function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test('Response includes Unauthorized message', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.msg).to.eql('Unauthorized');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/blacklists/{{dynamic_test_email}}",
              "host": ["{{base_url}}"],
              "path": ["blacklists", "{{dynamic_test_email}}"]
            }
          }
        },
        {
          "name": "Invalid Authentication Token - GET /blacklists",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401 Unauthorized', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer this-is-a-wrong-token",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/blacklists/{{dynamic_test_email}}",
              "host": ["{{base_url}}"],
              "path": ["blacklists", "{{dynamic_test_email}}"]
            }
          }
        },
        {
          "name": "Missing Required Field (Email) - POST /blacklists",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400 Bad Request', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Response indicates missing email', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.msg).to.include('email es obligatorio');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearer_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded",
                "type": "text"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "app_uuid",
                  "value": "{{app_uuid}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/blacklists",
              "host": ["{{base_url}}"],
              "path": ["blacklists"]
            }
          }
        }
      ]
    }
  ]
}
