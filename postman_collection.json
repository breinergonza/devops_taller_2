        {
          "name": "Bad Request - Missing Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearer_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "app_uuid",
                  "value": "{{app_uuid}}"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/blacklists",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "blacklists"
              ]
            },
            "description": "POST sin email - debe retornar 400"
          },
          "response": []
        }
      ]
    }
  ]
}
