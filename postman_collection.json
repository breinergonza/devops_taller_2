                  "pm.test('Status code is 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer invalid-token",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/blacklists/test@example.com",
              "host": [
