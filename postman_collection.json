{
    "info": {
        "_postman_id": "blacklist-api-collection",
        "name": "Blacklist Microservice API",
        "description": "Colección de endpoints para el microservicio de gestión de listas negras de emails. Incluye pruebas automatizadas y uso de variables dinámicas para validación completa.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://blacklist-alb-1329342580.us-east-1.elb.amazonaws.com",
            "type": "string",
            "description": "URL base del servidor activo (actualmente apuntando al ALB en AWS)"
        },
        {
            "key": "local_base_url",
            "value": "http://localhost:5000",
            "type": "string",
            "description": "URL base para pruebas en entorno local"
        },
        {
            "key": "bearer_token",
            "value": "uniandes-devops-2026",
            "type": "string",
            "description": "Token estático de autorización"
        },
        {
            "key": "dynamic_test_email",
            "value": "",
            "type": "string",
            "description": "Email autogenerado durante el flujo de pruebas"
        },
        {
            "key": "app_uuid",
            "value": "11111111-1111-1111-1111-111111111111",
            "type": "string",
            "description": "UUID de la aplicación simulada"
        },
        {
            "key": "stress_total_iterations",
            "value": "25",
            "type": "string",
            "description": "Total de ciclos del flujo de stress en Collection Runner/Newman"
        },
        {
            "key": "stress_iteration",
            "value": "0",
            "type": "string",
            "description": "Contador interno del flujo de stress"
        },
        {
            "key": "stress_last_email",
            "value": "",
            "type": "string",
            "description": "Ultimo email generado por el flujo de stress"
        },
        {
            "key": "run_controlled_error",
            "value": "false",
            "type": "string",
            "description": "Cambiar a true solo si ENABLE_ERROR_TEST_ENDPOINT=true en la app"
        }
    ],
    "item": [
        {
            "name": "Health & Info",
            "item": [
                {
                    "name": "Health Check - GET /ping",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('Response contains status ok', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.status).to.eql('ok');",
                                    "});",
                                    "",
                                    "pm.test('Response contains a valid timestamp', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.timestamp).to.exist;",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/ping",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "ping"
                            ]
                        },
                        "description": "Health check endpoint (no auth required)"
                    }
                },
                {
                    "name": "Service Info - GET /",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 200 or 404', function () {",
                                    "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                ""
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Blacklist Operations",
            "item": [
                {
                    "name": "Add Email to Blacklist - POST /blacklists",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "// Generamos un correo aleatorio para la prueba y lo guardamos en las variables de colección",
                                    "let randomId = Math.floor(Math.random() * 1000000);",
                                    "let generatedEmail = `automated_test_${randomId}@example.com`;",
                                    "pm.collectionVariables.set('dynamic_test_email', generatedEmail);",
                                    "console.log('Se utilizará el siguiente correo para la prueba dinámica: ' + generatedEmail);"
                                ],
                                "type": "text/javascript"
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 201 Created', function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "pm.test('Response includes confirmation message', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.msg).to.include('agregado');",
                                    "});",
                                    "",
                                    "pm.test('Response includes the created record id', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.id).to.be.a('number');",
                                    "});",
                                    "",
                                    "pm.test('Response matches the dynamically generated email', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    var expectedEmail = pm.collectionVariables.get('dynamic_test_email');",
                                    "    pm.expect(jsonData.email).to.eql(expectedEmail);",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{bearer_token}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/x-www-form-urlencoded",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "urlencoded",
                            "urlencoded": [
                                {
                                    "key": "email",
                                    "value": "{{dynamic_test_email}}",
                                    "type": "text"
                                },
                                {
                                    "key": "app_uuid",
                                    "value": "{{app_uuid}}",
                                    "type": "text"
                                },
                                {
                                    "key": "blocked_reason",
                                    "value": "Automated Postman Run Flow Test",
                                    "type": "text"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/blacklists",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "blacklists"
                            ]
                        }
                    }
                },
                {
                    "name": "Check Email Blacklist - GET /blacklists/{email}",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 200 OK', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('Email is correctly found in the blacklist (in_blacklist = true)', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.in_blacklist).to.be.true;",
                                    "});",
                                    "",
                                    "pm.test('Blocked reason matches what was submitted', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.blocked_reason).to.eql('Automated Postman Run Flow Test');",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{bearer_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/blacklists/{{dynamic_test_email}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "blacklists",
                                "{{dynamic_test_email}}"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Error Validation Flow",
            "item": [
                {
                    "name": "Missing Authentication Token - GET /blacklists",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 401 Unauthorized', function () {",
                                    "    pm.response.to.have.status(401);",
                                    "});",
                                    "",
                                    "pm.test('Response includes Unauthorized message', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.msg).to.eql('Unauthorized');",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/blacklists/{{dynamic_test_email}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "blacklists",
                                "{{dynamic_test_email}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Invalid Authentication Token - GET /blacklists",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 401 Unauthorized', function () {",
                                    "    pm.response.to.have.status(401);",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer this-is-a-wrong-token",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/blacklists/{{dynamic_test_email}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "blacklists",
                                "{{dynamic_test_email}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Missing Required Field (Email) - POST /blacklists",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 400 Bad Request', function () {",
                                    "    pm.response.to.have.status(400);",
                                    "});",
                                    "",
                                    "pm.test('Response indicates missing email', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.msg).to.include('email es obligatorio');",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{bearer_token}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/x-www-form-urlencoded",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "urlencoded",
                            "urlencoded": [
                                {
                                    "key": "app_uuid",
                                    "value": "{{app_uuid}}",
                                    "type": "text"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/blacklists",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "blacklists"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Stress & New Relic Monitoring",
            "description": "Flujo para generar trafico repetible y evidencias en New Relic APM, DB, Apdex, errores y alertas.",
            "item": [
                {
                    "name": "Reset Stress Variables - GET /observability/newrelic",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('New Relic status endpoint responds', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('License key is not exposed', function () {",
                                    "    pm.expect(pm.response.text()).to.not.include('NEW_RELIC_LICENSE_KEY');",
                                    "});",
                                    "",
                                    "pm.collectionVariables.set('stress_iteration', '0');",
                                    "pm.collectionVariables.set('stress_last_email', '');",
                                    "postman.setNextRequest('Stress Loop - GET /ping');"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/observability/newrelic",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "observability",
                                "newrelic"
                            ]
                        }
                    }
                },
                {
                    "name": "Stress Loop - GET /ping",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('ping returns 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('ping stays under 1000 ms', function () {",
                                    "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                                    "});",
                                    "",
                                    "postman.setNextRequest('Stress Loop - POST /blacklists');"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/ping",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "ping"
                            ]
                        }
                    }
                },
                {
                    "name": "Stress Loop - POST /blacklists",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const iteration = parseInt(pm.collectionVariables.get('stress_iteration') || '0', 10);",
                                    "const email = `postman_stress_${Date.now()}_${iteration}@example.com`;",
                                    "pm.collectionVariables.set('stress_last_email', email);"
                                ]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('blacklist POST returns 201', function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "pm.test('POST response has created id', function () {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(body.id).to.be.a('number');",
                                    "});",
                                    "",
                                    "postman.setNextRequest('Stress Loop - GET /blacklists/{email}');"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{bearer_token}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"{{stress_last_email}}\",\n  \"app_uuid\": \"{{app_uuid}}\",\n  \"blocked_reason\": \"postman-stress-new-relic\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/blacklists",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "blacklists"
                            ]
                        }
                    }
                },
                {
                    "name": "Stress Loop - GET /blacklists/{email}",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('blacklist GET returns 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('created email is found', function () {",
                                    "    const body = pm.response.json();",
                                    "    pm.expect(body.in_blacklist).to.eql(true);",
                                    "});",
                                    "",
                                    "const current = parseInt(pm.collectionVariables.get('stress_iteration') || '0', 10) + 1;",
                                    "const total = parseInt(pm.collectionVariables.get('stress_total_iterations') || '25', 10);",
                                    "pm.collectionVariables.set('stress_iteration', String(current));",
                                    "if (current < total) {",
                                    "    postman.setNextRequest('Stress Loop - Delay Marker');",
                                    "} else {",
                                    "    postman.setNextRequest('Optional Controlled Error - GET /debug/newrelic-error');",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{bearer_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/blacklists/{{stress_last_email}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "blacklists",
                                "{{stress_last_email}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Stress Loop - Delay Marker",
                    "description": "Request liviano para separar ciclos cuando se ejecuta desde Collection Runner/Newman.",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('delay marker returns 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "postman.setNextRequest('Stress Loop - GET /ping');"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/ping",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "ping"
                            ]
                        }
                    }
                },
                {
                    "name": "Optional Controlled Error - GET /debug/newrelic-error",
                    "description": "Usar solo si ENABLE_ERROR_TEST_ENDPOINT=true para evidenciar Errors Inbox.",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const enabled = pm.collectionVariables.get('run_controlled_error') === 'true';",
                                    "pm.test('controlled error status is expected', function () {",
                                    "    pm.expect(pm.response.code).to.eql(enabled ? 500 : 404);",
                                    "});",
                                    "postman.setNextRequest(null);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/debug/newrelic-error",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "debug",
                                "newrelic-error"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}
